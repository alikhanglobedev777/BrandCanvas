              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StoreListResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "brandcanvas_access": []
          }
        ],
        "summary": "List stores",
        "tags": [
          "Stores"
        ]
      },
      "post": {
        "operationId": "Store_create",
        "parameters": [],
        "requestBody": {
