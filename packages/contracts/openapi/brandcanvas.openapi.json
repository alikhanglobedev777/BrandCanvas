              }
            }
          }
        },
        "security": [
          {
            "brandcanvas_access": []
          }
        ],
        "summary": "Create a seller account and provision its store",
        "tags": [
          "Stores"
        ]
      }
    },
    "/api/v1/admin/stores/{storeId}": {
      "get": {
