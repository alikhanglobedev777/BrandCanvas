# Runtime
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
API_HOST=0.0.0.0
NEXT_PUBLIC_API_URL=http://localhost:4000

# PostgreSQL
POSTGRES_DB=brandcanvas
POSTGRES_USER=brandcanvas
POSTGRES_PASSWORD=brandcanvas_dev_password
DATABASE_URL=postgresql://brandcanvas:brandcanvas_dev_password@localhost:5434/brandcanvas

# Redis
REDIS_HOST_PORT=6381
REDIS_URL=redis://localhost:6381
WORKER_ENABLED=false

# Authentication placeholders - replace before production
COOKIE_SECRET=replace-with-a-long-random-cookie-secret

# Authentication
JWT_ACTIVE_KID=dev-2026-07
JWT_KEY_RING_JSON={"dev-2026-07":"replace-with-a-random-secret-at-least-32-characters-long"}
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_TOKEN_TTL_DAYS=30
SUPER_ADMIN_NAME=BrandCanvas Admin
SUPER_ADMIN_EMAIL=admin@brandcanvas.local
SUPER_ADMIN_PASSWORD=ChangeThisBeforeFirstLogin123!
