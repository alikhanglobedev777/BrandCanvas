{
  "name": "@brandcanvas/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup src/main.ts --format cjs --sourcemap --clean",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@brandcanvas/contracts": "workspace:*",
    "@brandcanvas/database": "workspace:*",
    "bullmq": "5.80.1",
    "dotenv": "17.4.2",
    "ioredis": "5.11.1"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "tsup": "8.5.1",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
